{
  "name": "qr-restaurant-ordering-system",
  "version": "1.0.0",
  "description": "A professional, bilingual (Khmer & English) QR-based restaurant ordering system built with Next.js 14.",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Heang0/qr-restaurant-ordering-system.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Heang0/qr-restaurant-ordering-system/issues"
  },
  "homepage": "https://github.com/Heang0/qr-restaurant-ordering-system#readme",
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
